<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trainings.Views.CategoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="{Binding Title}"
    Shell.BackgroundColor="#F24D65"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White">
    <VerticalStackLayout>
        <Label
            Margin="0,10,0,20"
            FontAttributes="Bold"
            FontSize="12"
            HorizontalOptions="Center"
            Text="Featured" />

        <Grid ColumnDefinitions="*, 2*" Margin="10,0,10,20">
            <Image
                Margin="0,0,10,0"
                Aspect="AspectFill"
                HeightRequest="105"
                Source="{Binding Image}" />

            <StackLayout Grid.Column="1">
                <Label FontSize="26" Text="Unity" />

                <Label FontSize="16" Text="Develop C# games." />

                <HorizontalStackLayout>
                    <Image Source="star.png" />

                    <Image Source="star.png" />

                    <Image Source="star.png" />

                    <Image Source="star.png" />

                    <Image Source="star.png" />
                </HorizontalStackLayout>
            </StackLayout>
        </Grid>

        <Label
            Margin="0,10,0,20"
            HorizontalOptions="Center"
            Text="Best training videos" />

        <Label
            Margin="0,10,0,20"
            HorizontalOptions="Center"
            Text="{Binding Description}" />

        <BoxView
            Margin="0,0,0,20"
            BackgroundColor="#ECECEC"
            HeightRequest="1"
            WidthRequest="300" />

        <Label
            x:Name="NoCoursesErrorLabel"
            Margin="20"
            HorizontalOptions="Center"
            Text="No trainings found"
            TextColor="#F24D65" />

        <ListView
            x:Name="TrainingsListView"
            Margin="5"
            BackgroundColor="White"
            HeightRequest="440"
            ItemSelected="OnTrainingItemSelected"
            SeparatorColor="Transparent">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ImageCell
                        Detail="{Binding Description}"
                        ImageSource="{Binding Image}"
                        Text="{Binding FullTitle}"
                        TextColor="#323A45" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </VerticalStackLayout>
</ContentPage>