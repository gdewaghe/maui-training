<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trainings.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.BackgroundColor="#F24D65"
    Shell.TitleColor="White">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIcons-Regular" Glyph="&#xe7fd;" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <StackLayout Margin="20">
        <Border
            Margin="0,0,0,20"
            Padding="10,2"
            BackgroundColor="#ECECEC"
            Stroke="Transparent">
            <Entry BackgroundColor="Transparent" Placeholder="Research..." />
        </Border>
    </StackLayout>
</ContentPage>
