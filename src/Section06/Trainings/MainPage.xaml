<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Trainings.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.BackgroundColor="#F24D65"
    Shell.TitleColor="White">
    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="ToolbarItem_Clicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="MaterialIcons-Regular" Glyph="&#xe7fd;" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <StackLayout Margin="20">
        <Border
            Margin="0,0,0,20"
            Padding="10,2"
            BackgroundColor="#ECECEC"
            Stroke="Transparent">
            <Entry BackgroundColor="Transparent" Placeholder="Research..." />
        </Border>

        <CollectionView x:Name="categoriesCollectionView" />

        <Grid
            RowDefinitions="Auto"
            ColumnDefinitions="Auto,2*"
            BackgroundColor="White">
            <Image
                Margin="0,0,20,0"
                Aspect="AspectFill"
                HeightRequest="80"
                Source="icon_design.png" />

            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="18"
                Text="Title example" />

            <Label
                Grid.Column="1"
                FontSize="16"
                LineHeight=".8"
                Text="Lorem ipsum dolor sit amet. Lorem ipsum dolor sit amet."
                VerticalOptions="Center" />

            <HorizontalStackLayout Grid.Column="1">
                <Label
                    Padding="0,0,4,0"
                    Text="42"
                    VerticalOptions="End" />

                <Label Text="courses" VerticalOptions="End" />
            </HorizontalStackLayout>
        </Grid>
    </StackLayout>
</ContentPage>
