<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PcCleaner.Views.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="White">
    <VerticalStackLayout Padding="0">
        <!-- Top menu with PC specs -->
        <Frame
            BackgroundColor="#444"
            BorderColor="#444"
            CornerRadius="0"
            HeightRequest="100">
            <FlexLayout Padding="0" Direction="Row">
                <!-- Logo -->
                <Image
                    Margin="0,0,5,0"
                    Source="pcclogo.png"
                    WidthRequest="60" />

                <!-- Name + version -->
                <VerticalStackLayout Margin="0">
                    <Label
                        FontAttributes="Bold"
                        FontSize="Title"
                        Text="PC Cleaner" />

                    <Label Text="v1.4.0" />
                </VerticalStackLayout>

                <!-- Add spaces -->
                <Label WidthRequest="80" />

                <!-- Specs -->
                <VerticalStackLayout FlexLayout.Grow="1">
                    <Label x:Name="OsVersionLabel" Text="Microsoft Windows X" />
                    <Label x:Name="HardwareLabel" Text="xxxxx" />
                </VerticalStackLayout>

                <!-- Info -->
                <ImageButton
                    BackgroundColor="#444"
                    Clicked="OnInfoClicked"
                    Source="info.png"
                    WidthRequest="50" />
            </FlexLayout>
        </Frame>

        <AbsoluteLayout>
            <!-- Left side menu -->
            <Frame
                Padding="0"
                AbsoluteLayout.LayoutBounds="0,0,0.075,1"
                AbsoluteLayout.LayoutFlags="All"
                BackgroundColor="#666"
                BorderColor="#666"
                CornerRadius="0"
                MinimumWidthRequest="80" />

            <!-- Main content area -->
            <VerticalStackLayout AbsoluteLayout.LayoutBounds="1,0,0.925,1" AbsoluteLayout.LayoutFlags="All">
                <Frame
                    Margin="0"
                    Padding="0"
                    BackgroundColor="White"
                    BorderColor="#fff"
                    CornerRadius="0"
                    MinimumHeightRequest="585" />
            </VerticalStackLayout>

            <!-- Footer -->
            <Frame
                AbsoluteLayout.LayoutBounds="0,585,1,AutoSize"
                AbsoluteLayout.LayoutFlags="WidthProportional"
                BackgroundColor="#333"
                BorderColor="#333"
                CornerRadius="0"
                HeightRequest="60">
                <Label
                    HorizontalTextAlignment="End"
                    Text="PC Cleaner"
                    TextDecorations="Underline"
                    VerticalTextAlignment="Center" />
            </Frame>
        </AbsoluteLayout>
    </VerticalStackLayout>
</ContentPage>
